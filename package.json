{
  "name": "real-estate-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Real Estate Intelligence Platform — NestJS Monorepo",
  "scripts": {
    "build": "nest build",
    "build:api": "nest build api",
    "build:logger": "nest build logger",
    "start:api": "node dist/apps/api/main",
    "start:logger": "node dist/apps/logger/main",
    "start:dev:api": "nest start api --watch",
    "start:dev:logger": "nest start logger --watch",
    "lint": "eslint \"{apps,libs}/**/*.ts\"",
    "format": "prettier --write \"{apps,libs}/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/bull": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/event-emitter": "^2.1.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/microservices": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.4.0",
    "bull": "^4.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "imapflow": "^1.0.170",
    "ioredis": "^5.4.0",
    "kafkajs": "^2.2.4",
    "nestjs-pino": "^4.1.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.48.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bull": "^4.10.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "webpack": "^5.97.0",
    "webpack-node-externals": "^3.0.0"
  }
}
